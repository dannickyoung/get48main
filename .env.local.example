# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase Dashboard → Project Settings → API

# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SERVER ONLY. Never expose to the browser. Used to invite
# clients and run admin-only writes that bypass RLS in trusted server code.
SUPABASE_SERVICE_ROLE_KEY=

# The email address that gets the single admin account (you).
# Must match the email you log in with.
NEXT_PUBLIC_ADMIN_EMAIL=

# --- Email reminders (optional) ---
# Gmail address + 16-char App Password (Google Account → Security → App passwords).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# A random secret guarding the cron endpoint. Vercel Cron sends it as a Bearer token.
CRON_SECRET=
